local function getValue(folder, name)
    local stat = folder:FindFirstChild(name)
    if stat and stat:IsA("ValueBase") then
        return stat.Value
    end
    return 0
end

local function waitForFruitsFolder()
    local otherData = LocalPlayer:WaitForChild("OtherData", 5)
    if not otherData then return nil end
    return otherData:WaitForChild("Fruits", 5)
end

