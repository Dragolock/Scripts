local function getCharacter()
    local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local humanoid = character:WaitForChild("Humanoid")
    local root = character:WaitForChild("HumanoidRootPart")
    return character, humanoid, root
end

local function tp(x, y, z)
    local _, _, root = getCharacter()
    root.CFrame = CFrame.new(x, y, z)
end

local function clickTargetDetectors(delayTime)
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("ClickDetector") then
            local parent = obj.Parent
            if parent and (parent.Name == "n" or parent.Name == "Clicks") then
                pcall(function()
                    fireclickdetector(obj)
                end)
            end
        end
    end
    task.wait(delayTime)
end

local function startHeartbeatTeleport(optionName, targetCFrame)
    task.spawn(function()
        local character, _, root = getCharacter()
        local conn
        conn = RunService.Heartbeat:Connect(function()
            if not Options[optionName].Value then
                conn:Disconnect()
                return
            end
            if root and root.Parent then
                root.CFrame = targetCFrame
            end
        end)
    end)
end

