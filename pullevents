local RunService = game:GetService("RunService")

local tpwalking
local tpSpeed = 1

local Slider = Tabs.player:CreateSlider("TPWalkSpeed", {
    Title = "Walk Speed Increase",
    Description = "",
    Default = 1,
    Min = 1,
    Max = 10,
    Rounding = 1,
    Callback = function(Value)
        tpSpeed = Value
        print("TP Speed changed to:", Value)
    end
})

local function startTPWalk()
    pcall(function()
        if tpwalking then
            tpwalking:Disconnect()
        end
    end)

    local character = game.Players.LocalPlayer.Character
    local humanoid = character and character:FindFirstChildWhichIsA("Humanoid")

    tpwalking = RunService.Heartbeat:Connect(function(delta)
        if not (character and humanoid and humanoid.Parent) then
            tpwalking:Disconnect()
            return
        end

        if humanoid.MoveDirection.Magnitude > 0 then
            character:TranslateBy(humanoid.MoveDirection * tpSpeed * delta * 10)
        end
    end)
end

startTPWalk()

