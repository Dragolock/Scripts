Tabs.dungeon:CreateToggle("TPHolyEnemies", {Title = "TP Holy Enemies", Default = false})
:OnChanged(function(state)

    local player = game.Players.LocalPlayer
    local character = player.Character or player.CharacterAdded:Wait()
    local hrp = character:WaitForChild("HumanoidRootPart")
    local humanoid = character:FindFirstChildOfClass("Humanoid")

    if not state then return end

    local torsos = {}

    local function addTorso(v)
        if v:IsA("BasePart") and v.Name == "UpperTorso" then
            local model = v:FindFirstAncestorOfClass("Model")
            if model and not game.Players:GetPlayerFromCharacter(model) then
                torsos[v] = true
            end
        end
    end

    local function removeTorso(v)
        torsos[v] = nil
    end

    for _, v in ipairs(workspace:GetDescendants()) do
        addTorso(v)
    end

    local addedConn = workspace.DescendantAdded:Connect(addTorso)
    local removedConn = workspace.DescendantRemoving:Connect(removeTorso)

    task.spawn(function()
     while Options.TPHolyEnemies.Value and character.Parent do
    local nearest, shortest = nil, MAX_RADIUS

    for torso in pairs(torsos) do
        if torso and torso.Parent then
            local dist = (hrp.Position - torso.Position).Magnitude

            if dist <= MAX_RADIUS and dist < shortest then
                shortest = dist
                nearest = torso
            end
        end
    end

    if nearest then
        if humanoid and humanoid.Sit then
            humanoid.Sit = false
        end

        hrp.CFrame = CFrame.new(
            nearest.Position + Vector3.new(offsetX, offsetY, offsetZ)
        )
    end

    task.wait(0.01)
end

        addedConn:Disconnect()
        removedConn:Disconnect()
        table.clear(torsos)
    end)
end)

