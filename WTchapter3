Tabs.easter:CreateToggle("CollectEggs", {
    Title = "Collect Eggs",
    Default = false
}):OnChanged(function(state)
    if state then
        task.spawn(function()
            local folder = workspace:WaitForChild("ActiveEggs")
            local prompts = {}

            for _, obj in ipairs(folder:GetDescendants()) do
                if obj:IsA("ProximityPrompt") then
                    table.insert(prompts, obj)
                end
            end

            local connection
            connection = folder.DescendantAdded:Connect(function(obj)
                if obj:IsA("ProximityPrompt") then
                    table.insert(prompts, obj)
                end
            end)

            while Options.CollectEggs.Value do
                for i = #prompts, 1, -1 do
                    local prompt = prompts[i]

                    if not prompt or not prompt.Parent then
                        table.remove(prompts, i)
                    else
                        fireproximityprompt(prompt)
                    end
                end
                task.wait(10)
            end
            if connection then
                connection:Disconnect()
            end
        end)
    end
end)

