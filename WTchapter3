local Options = Library.Options

Tabs.mainTab:CreateToggle("AutoConvert", {
    Title = "Auto Convert",
    Default = false
})
:OnChanged(function(state)
    if state then
        task.spawn(function()
            local RunService = game:GetService("RunService")
            local player = game.Players.LocalPlayer

            local connection
            connection = RunService.Heartbeat:Connect(function()
                if not Options.AutoConvert.Value then
                    if connection then
                        connection:Disconnect()
                    end
                    return
                end

                local character = player.Character
                if character then
                    local root = character:FindFirstChild("HumanoidRootPart")
                    if root then
                        root.CFrame = CFrame.new(53, 9, -114)
                    end
                end
            end)
        end)
    end
end)

local RunService = game:GetService("RunService")
local Players = game:GetService("Players")

Tabs.mainTab:CreateToggle("TPLevelArea", {
    Title = "TP Level Area",
    Default = false
})
:OnChanged(function(state)

    local player = Players.LocalPlayer

    local START_POSITION = Vector3.new(110, 90, -235)
    local TARGET_POSITION = Vector3.new(137, 91, -226)
    local LERP_SPEED = 0.1

    local function getCharacter()
        return player.Character
    end

    local function getHumanoid(char)
        return char and char:FindFirstChildOfClass("Humanoid")
    end

    local function getRoot(char)
        return char and char:FindFirstChild("HumanoidRootPart")
    end

    if state then
        task.spawn(function()
            local character = getCharacter()
            local humanoid = getHumanoid(character)
            local root = getRoot(character)

            if not (character and humanoid and root) then return end

            root.CFrame = CFrame.new(START_POSITION)

            local targetCFrame = CFrame.new(TARGET_POSITION)

            while Options.TPLevelArea.Value and (root.Position - TARGET_POSITION).Magnitude > 0.5 do
                root.CFrame = root.CFrame:Lerp(targetCFrame, LERP_SPEED)
                RunService.RenderStepped:Wait()
            end

            task.wait(1)

            humanoid.WalkSpeed = 0
            humanoid.JumpPower = 0
            humanoid.AutoRotate = false

            while Options.TPLevelArea.Value do
                root.AssemblyLinearVelocity = Vector3.zero
                root.AssemblyAngularVelocity = Vector3.zero
                RunService.RenderStepped:Wait()
            end
        end)

    else
        local character = player.Character
        if character then
            local humanoid = character:FindFirstChildOfClass("Humanoid")
            local root = character:FindFirstChild("HumanoidRootPart")

            if humanoid then
                humanoid.WalkSpeed = 16
                humanoid.JumpPower = 50
                humanoid.AutoRotate = true
            end

            if root then
                root.AssemblyLinearVelocity = Vector3.zero
                root.AssemblyAngularVelocity = Vector3.zero
            end
        end
    end
end)

