Tabs.mainTab:CreateToggle("AutoLerpPos", {
    Title = "Essence Zone",
    Default = false
})
:OnChanged(function(state)

    local player = game.Players.LocalPlayer
    local RunService = game:GetService("RunService")

    if state then
        task.spawn(function()

            local character = player.Character or player.CharacterAdded:Wait()
            local root = character:WaitForChild("HumanoidRootPart")
            local humanoid = character:WaitForChild("Humanoid")

            local function lerpToPosition(targetPos, duration)
                local startCFrame = root.CFrame
                local endCFrame = CFrame.new(targetPos)
                local startTime = tick()

                while Options.AutoLerpPos.Value do
                    local elapsed = tick() - startTime
                    local alpha = math.clamp(elapsed / duration, 0, 1)

                    root.CFrame = startCFrame:Lerp(endCFrame, alpha)

                    if alpha >= 1 then break end
                    RunService.RenderStepped:Wait()
                end
            end

            root.CFrame = CFrame.new(115, 475, 2482)
            if not Options.AutoLerpPos.Value then return end

            task.wait(0.5)
            if not Options.AutoLerpPos.Value then return end

            lerpToPosition(Vector3.new(49, 469, 2474), 1.2)
            if not Options.AutoLerpPos.Value then return end

            task.wait(1)
            if not Options.AutoLerpPos.Value then return end

            humanoid.WalkSpeed = 0
            humanoid.JumpPower = 0
            humanoid.AutoRotate = false

            while Options.AutoLerpPos.Value do
                root.AssemblyLinearVelocity = Vector3.zero
                root.AssemblyAngularVelocity = Vector3.zero
                RunService.RenderStepped:Wait()
            end

        end)

    else
        local character = player.Character
        if character then
            local humanoid = character:FindFirstChildOfClass("Humanoid")
            local root = character:FindFirstChild("HumanoidRootPart")

            if humanoid then
                humanoid.WalkSpeed = 16
                humanoid.JumpPower = 50
                humanoid.AutoRotate = true
            end

            if root then
                root.AssemblyLinearVelocity = Vector3.zero
                root.AssemblyAngularVelocity = Vector3.zero
            end
        end
    end
end)
