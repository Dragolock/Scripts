local LemonsParagraph = Tabs.stats:CreateParagraph("LemonsCount", {Title = "Lemons", Content = "", TitleAlignment = "Left", ContentAlignment = Enum.TextXAlignment.Left})
local LimesParagraph = Tabs.stats:CreateParagraph("LimesCount", {Title = "Limes", Content = "", TitleAlignment = "Left", ContentAlignment = Enum.TextXAlignment.Left})
local OrangesParagraph = Tabs.stats:CreateParagraph("OrangesCount", {Title = "Oranges", Content = "", TitleAlignment = "Left", ContentAlignment = Enum.TextXAlignment.Left})
local TangerinesParagraph = Tabs.stats:CreateParagraph("TangerinesCount", {Title = "Tangerines", Content = "", TitleAlignment = "Left", ContentAlignment = Enum.TextXAlignment.Left})

local fruitMap = {
    Lemons = LemonsParagraph,
    Limes = LimesParagraph,
    Oranges = OrangesParagraph,
    Tangerines = TangerinesParagraph
}

local function getValue(folder, name)
    local stat = folder:FindFirstChild(name)
    if stat and stat:IsA("ValueBase") then
        return stat.Value
    end
    return 0
end

local function waitForFruitsFolder(player)
    local otherData = player:WaitForChild("OtherData", 5)
    if not otherData then return nil end
    local fruitsFolder = otherData:WaitForChild("Fruits", 5)
    return fruitsFolder
end

local function updateFruitParagraphs()
    local fruitsFolder = waitForFruitsFolder(localPlayer)
    for fruitName, paragraph in pairs(fruitMap) do
        local value = fruitsFolder and getValue(fruitsFolder, fruitName) or "N/A"
        paragraph:SetValue(tostring(value))
    end
end

Tabs.stats:CreateButton({
    Title = "Refresh Fruits",
    Description = "Manually refresh fruit amounts",
    Callback = updateFruitParagraphs
})

task.spawn(function()
    while true do
        updateFruitParagraphs()
        task.wait(3)
    end
end)

